<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>웹 기술의 이해 - 가이드</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --bg-color: #defffc;
            --light-color: #e2e4f6;
            --accent-color: #e7c8dd;
            --deep-accent: #d8afc1;
            --text-color: #86626e;
        }
        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, Roboto, sans-serif;
        }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        .tab-button.active {
            background-color: var(--accent-color);
            transform: scale(1.05);
            font-weight: bold;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        }
        .modal { display: none; }
        .modal.active { display: flex; }
    </style>
</head>
<body class="selection:bg-pink-200">

    <!-- Header -->
    <header class="p-8 text-center bg-white/50 backdrop-blur-sm sticky top-0 z-50 border-b border-white/20">
        <h1 class="text-3xl md:text-4xl font-bold mb-2 flex items-center justify-center gap-3">
            <i data-lucide="book-open" class="w-8 h-8"></i> 웹 기술의 이해
        </h1>
        <p class="opacity-80 mb-6">누구나 알기 쉬운 웹과 모바일의 기초 가이드</p>
        
        <!-- Quick Access Buttons -->
        <div class="flex justify-center gap-3 flex-wrap">
            <button onclick="toggleModal(true)" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-white/80 hover:bg-white transition-all shadow-sm border border-gray-100 text-sm font-medium hover:-translate-y-0.5">
                <i data-lucide="image" class="w-4 h-4 text-blue-400"></i> 인포그래픽 보기
            </button>
            <button class="flex items-center gap-2 px-4 py-2 rounded-lg bg-white/80 hover:bg-white transition-all shadow-sm border border-gray-100 text-sm font-medium hover:-translate-y-0.5">
                <i data-lucide="play-circle" class="w-4 h-4 text-red-400"></i> 동영상 강의
            </button>
            <button class="flex items-center gap-2 px-4 py-2 rounded-lg bg-white/80 hover:bg-white transition-all shadow-sm border border-gray-100 text-sm font-medium hover:-translate-y-0.5">
                <i data-lucide="presentation" class="w-4 h-4 text-purple-400"></i> 슬라이드 자료
            </button>
        </div>
    </header>

    <!-- Modal for Infographic -->
    <div id="infoModal" class="modal fixed inset-0 z-[100] items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
        <div class="relative bg-white p-2 rounded-2xl max-w-4xl w-full shadow-2xl overflow-hidden">
            <button onclick="toggleModal(false)" class="absolute top-4 right-4 p-2 bg-black/10 hover:bg-black/20 rounded-full transition-colors z-10">
                <i data-lucide="x" class="w-6 h-6 text-white"></i>
            </button>
            <div class="flex flex-col">
                <div id="imageContainer" class="bg-gray-100 rounded-xl overflow-hidden flex items-center justify-center min-h-[300px]">
                    <img src="webinfographic.png" alt="웹 기술 인포그래픽" class="max-h-[80vh] w-auto object-contain" id="infographicImg">
                </div>
                <div class="p-4 text-center">
                    <p class="font-bold text-lg">웹 기술 핵심 인포그래픽</p>
                    <p class="text-sm opacity-60">HTML, CSS, JS의 구조를 한눈에 확인하세요.</p>
                </div>
            </div>
        </div>
    </div>

    <main class="max-w-4xl mx-auto p-6 md:p-10 space-y-12">
        
        <!-- Navigation Tabs -->
        <nav class="flex justify-center gap-4 flex-wrap">
            <button onclick="switchTab('elements')" id="btn-elements" class="tab-button flex items-center gap-2 px-6 py-3 rounded-full bg-white/60 hover:bg-white/90 transition-all shadow-sm active">
                <i data-lucide="home" class="w-4 h-4"></i> 웹의 3요소
            </button>
            <button onclick="switchTab('mobile')" id="btn-mobile" class="tab-button flex items-center gap-2 px-6 py-3 rounded-full bg-white/60 hover:bg-white/90 transition-all shadow-sm">
                <i data-lucide="smartphone" class="w-4 h-4"></i> 모바일 서비스
            </button>
            <button onclick="switchTab('api')" id="btn-api" class="tab-button flex items-center gap-2 px-6 py-3 rounded-full bg-white/60 hover:bg-white/90 transition-all shadow-sm">
                <i data-lucide="share-2" class="w-4 h-4"></i> API와 매시업
            </button>
        </nav>

        <!-- Tab 1: Elements -->
        <section id="content-elements" class="tab-content active transition-all duration-500">
            <div class="bg-white/40 p-8 rounded-3xl border border-white/30 shadow-lg">
                <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
                    <i data-lucide="layers" class="text-pink-400"></i> 웹 개발의 삼중주
                </h2>
                <div class="grid md:grid-cols-3 gap-6">
                    <div class="p-6 rounded-2xl bg-white/80 hover:shadow-md transition-shadow">
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 bg-[#e2e4f6]">
                            <i data-lucide="layout" class="w-6 h-6"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-2">HTML</h3>
                        <p class="text-sm leading-relaxed mb-4"><strong>구조(Structure)</strong>를 담당해요. 집으로 치면 벽과 뼈대를 세우는 마크업 언어입니다.</p>
                        <span class="text-xs px-2 py-1 rounded-full bg-blue-50 text-blue-600">#무엇이있는가</span>
                    </div>
                    <div class="p-6 rounded-2xl bg-white/80 hover:shadow-md transition-shadow">
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 bg-[#e7c8dd]">
                            <i data-lucide="palette" class="w-6 h-6"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-2">CSS</h3>
                        <p class="text-sm leading-relaxed mb-4"><strong>스타일(Style)</strong>을 담당해요. 벽지를 바르고 가구를 배치하여 예쁘게 꾸미는 역할을 합니다.</p>
                        <span class="text-xs px-2 py-1 rounded-full bg-pink-50 text-pink-600">#어떻게보이는가</span>
                    </div>
                    <div class="p-6 rounded-2xl bg-white/80 hover:shadow-md transition-shadow">
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 bg-[#d8afc1]">
                            <i data-lucide="zap" class="w-6 h-6 text-white"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-2">JavaScript</h3>
                        <p class="text-sm leading-relaxed mb-4"><strong>동작(Behavior)</strong>을 담당해요. 전등을 켜거나 자동문을 작동시키는 등의 상호작용을 만듭니다.</p>
                        <span class="text-xs px-2 py-1 rounded-full bg-purple-50 text-purple-600">#어떻게행동하는가</span>
                    </div>
                </div>

                <div class="mt-10 p-6 rounded-2xl bg-white/50 border border-dashed border-gray-300">
                    <h4 class="font-bold mb-4 flex items-center gap-2"><i data-lucide="info" class="w-4 h-4"></i> 자바스크립트 체험해보기</h4>
                    <div class="flex flex-col items-center gap-4">
                        <p class="text-sm italic">"버튼을 클릭하면 자바스크립트가 동작합니다!"</p>
                        <button onclick="toggleJsDemo()" class="px-8 py-3 rounded-xl font-bold text-white transition-all active:scale-95 bg-[#d8afc1]">
                            마법 부리기 (JS 클릭!)
                        </button>
                        <div id="jsDemoMsg" class="hidden mt-4 p-4 rounded-lg bg-yellow-100 text-yellow-800 animate-bounce">
                            ✨ 웹페이지가 살아 움직이기 시작했어요!
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Tab 2: Mobile -->
        <section id="content-mobile" class="tab-content transition-all duration-500 space-y-8">
            <div class="text-center">
                <h2 class="text-2xl font-bold mb-2">모바일 서비스 전략</h2>
                <p class="opacity-80">목적에 맞는 방식을 선택하는 것이 중요합니다.</p>
            </div>

            <div class="grid md:grid-cols-3 gap-4">
                <div onclick="showMobileDetail('native')" id="card-native" class="mobile-card cursor-pointer p-6 rounded-3xl border-2 border-transparent bg-white/40 transition-all hover:bg-white/60">
                    <div class="mb-4 text-pink-400"><i data-lucide="zap"></i></div>
                    <h3 class="font-bold mb-2 text-lg">네이티브 앱</h3>
                    <p class="text-sm opacity-70">클릭해서 상세 특징 확인</p>
                </div>
                <div onclick="showMobileDetail('web')" id="card-web" class="mobile-card cursor-pointer p-6 rounded-3xl border-2 border-transparent bg-white/40 transition-all hover:bg-white/60">
                    <div class="mb-4 text-pink-400"><i data-lucide="layers"></i></div>
                    <h3 class="font-bold mb-2 text-lg">웹 앱</h3>
                    <p class="text-sm opacity-70">클릭해서 상세 특징 확인</p>
                </div>
                <div onclick="showMobileDetail('hybrid')" id="card-hybrid" class="mobile-card cursor-pointer p-6 rounded-3xl border-2 border-transparent bg-white/40 transition-all hover:bg-white/60">
                    <div class="mb-4 text-pink-400"><i data-lucide="smartphone"></i></div>
                    <h3 class="font-bold mb-2 text-lg">하이브리드 앱</h3>
                    <p class="text-sm opacity-70">클릭해서 상세 특징 확인</p>
                </div>
            </div>

            <div id="mobileDetail" class="hidden p-8 rounded-3xl bg-white shadow-inner scale-95 transition-all">
                <h3 id="detailTitle" class="text-xl font-bold mb-4"></h3>
                <p id="detailDesc" class="mb-6 leading-relaxed"></p>
                <div class="grid grid-cols-2 gap-4">
                    <div class="p-4 rounded-xl bg-[#defffc]">
                        <span class="font-bold block mb-1">장점</span>
                        <span id="detailPros" class="text-sm"></span>
                    </div>
                    <div class="p-4 rounded-xl bg-[#e2e4f6]">
                        <span class="font-bold block mb-1">단점</span>
                        <span id="detailCons" class="text-sm"></span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Tab 3: API -->
        <section id="content-api" class="tab-content transition-all duration-500">
            <div class="bg-white/40 p-8 rounded-3xl border border-white/30 shadow-lg">
                <div class="flex flex-col md:flex-row gap-8 items-center">
                    <div class="flex-1">
                        <h2 class="text-2xl font-bold mb-4 flex items-center gap-2">
                            <i data-lucide="share-2" class="text-indigo-400"></i> API와 매시업(Mash-up)
                        </h2>
                        <p class="mb-4 leading-relaxed">
                            <strong>API</strong>는 서로 다른 시스템이 대화하는 규칙이에요. 기업들이 정보를 공개하면(Open API), 
                            똑똑한 개발자들이 이를 섞어서(Mash-up) 새로운 가치를 만듭니다.
                        </p>
                        <ul class="space-y-2">
                            <li class="flex items-center gap-2 text-sm"><i data-lucide="chevron-right" class="w-4 h-4 text-pink-400"></i> 호갱노노: 공공데이터 + 지도 API</li>
                            <li class="flex items-center gap-2 text-sm"><i data-lucide="chevron-right" class="w-4 h-4 text-pink-400"></i> 핀플리: 유튜브 API 활용</li>
                        </ul>
                    </div>
                    <div class="w-full md:w-1/3 p-6 rounded-2xl bg-indigo-50 border border-indigo-100 flex flex-col items-center text-center">
                        <div class="text-4xl mb-2">🧩</div>
                        <p class="text-xs font-bold text-indigo-600 uppercase tracking-widest mb-2">API Economy</p>
                        <p class="text-sm">데이터를 연결하여<br/>새로운 세상을 만들어요</p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer class="mt-20 p-10 text-center border-t border-white/20 bg-[#e2e4f6]">
        <p class="text-sm opacity-60">© 2024 웹 기술 입문 가이드 | HTML, CSS, JavaScript의 조화</p>
    </footer>

    <script>
        // Lucide 아이콘 초기화
        lucide.createIcons();

        // 탭 전환 기능
        function switchTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.tab-button').forEach(el => el.classList.remove('active'));
            
            document.getElementById('content-' + tabId).classList.add('active');
            document.getElementById('btn-' + tabId).classList.add('active');
        }

        // JS 데모 기능
        function toggleJsDemo() {
            const msg = document.getElementById('jsDemoMsg');
            msg.classList.toggle('hidden');
        }

        // 모달 제어
        function toggleModal(show) {
            const modal = document.getElementById('infoModal');
            if(show) modal.classList.add('active');
            else modal.classList.remove('active');
        }

        // 모바일 상세 정보 데이터
        const mobileData = {
            native: {
                name: '네이티브 앱',
                desc: 'OS 전용 언어(Java, Swift)로 개발. 가장 빠르고 기기 기능을 완벽하게 사용해요.',
                pros: '최고의 속도, 최적화',
                cons: '높은 비용, 개별 개발'
            },
            web: {
                name: '웹 앱',
                desc: '웹 기술로 제작되었지만 앱처럼 동작해요. 설치가 필요 없고 비용이 저렴하죠.',
                pros: '낮은 비용, 빠른 업데이트',
                cons: '하드웨어 접근 제한'
            },
            hybrid: {
                name: '하이브리드 앱',
                desc: '네이티브 앱 안에 웹을 담았어요. 유지보수가 쉽고 기기 기능도 쓸 수 있죠.',
                pros: '하이브리드 장점 결합',
                cons: '성능의 제약성'
            }
        };

        function showMobileDetail(type) {
            const detail = document.getElementById('mobileDetail');
            const data = mobileData[type];

            document.getElementById('detailTitle').innerText = data.name + '의 특징';
            document.getElementById('detailDesc').innerText = data.desc;
            document.getElementById('detailPros').innerText = data.pros;
            document.getElementById('detailCons').innerText = data.cons;

            detail.classList.remove('hidden');
            setTimeout(() => detail.classList.remove('scale-95'), 10);

            // 카드 스타일 변경
            document.querySelectorAll('.mobile-card').forEach(el => {
                el.classList.remove('bg-white', 'shadow-xl', 'border-[#e7c8dd]');
            });
            const activeCard = document.getElementById('card-' + type);
            activeCard.classList.add('bg-white', 'shadow-xl', 'border-[#e7c8dd]');
        }

        // 이미지 오류 처리
        document.getElementById('infographicImg').onerror = function() {
            const container = document.getElementById('imageContainer');
            container.innerHTML = `
                <div class="flex flex-col items-center gap-4 p-20 text-gray-400">
                    <i data-lucide="image-off" class="w-12 h-12"></i>
                    <p class="font-medium">이미지(webinfographic.png)를 불러올 수 없습니다.</p>
                </div>
            `;
            lucide.createIcons();
        };

        // ESC 키로 모달 닫기
        window.addEventListener('keydown', (e) => {
            if(e.key === 'Escape') toggleModal(false);
        });
    </script>
</body>
</html>
